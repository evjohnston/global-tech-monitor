# Copy to .env.local (already gitignored via *.local) and fill in once the
# worker/ Cloudflare Worker is deployed. Leave unset and the app just skips
# live patents/funding reads — same soft-fail ethos as the nightly build.
VITE_WORKER_URL=https://gtm-live-proxy.<your-subdomain>.workers.dev

# Read by scripts/fetch-data.ts, backfill-entries.ts, and backfill-trend.ts
# when run locally via tsx (loaded explicitly — Vite's own .env.local loading
# doesn't apply outside `npm run dev`/`build`). Same variable names as the
# GitHub Actions repo secrets and the Cloudflare Worker secrets — independent
# stores, set this one too if you want real patents/higher OpenAlex rate
# limits on a local `npm run fetch-data`. Leave unset and those sources just
# soft-fail locally, same as everywhere else.
OPENALEX_KEY=
EPO_KEY=
EPO_SECRET=
